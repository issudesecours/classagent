OPENAI_API_KEY=sk-...
# Model used by the orchestrator agent.
# gpt-4.1 is the safe default. Use gpt-4.1-mini for cost, or a stronger
# model (e.g. gpt-5 if available on your account) for tougher lectures.
ORCHESTRATOR_MODEL=gpt-4.1
# How many of the most recent session items to feed back to the model
# each tick. Older items stay in the in-memory DB but aren't re-sent.
# Higher = more short-range continuity, more tokens. ~80 ≈ 10–15 minutes
# of recent detail at our tick rate.
ORCHESTRATOR_HISTORY_LIMIT=80
# Where to persist transcript.md and cards.json per session
DATA_DIR=./data
